{
  "_readme": "Pre-computed FK relationships. Use this to determine JOIN paths without reading CSVs. Each entry: from_table.from_column -> to_table (resolved in same schema unless cross_schema=true).",
  "configadm": {
    "param_config": {
      "joins": [
        { "fk": "param_key_id",           "to_table": "param_key",           "to_col": "param_key_id" },
        { "fk": "association_id",          "to_table": "association",          "to_col": "association_id" },
        { "fk": "parent_association_id",   "to_table": "association",          "to_col": "association_id" }
      ],
      "note": "Core config table. Always join param_key for rule name, association for scope (COUNTRY/STORE/STATE)."
    },
    "param_config_list_of_value": {
      "joins": [
        { "fk": "param_config_id", "to_table": "param_config", "to_col": "param_config_id" }
      ],
      "note": "The actual configured value(s) for a param_config row."
    },
    "param_key": {
      "joins": [
        { "fk": "param_group_id",             "to_table": "param_group",             "to_col": "param_group_id" },
        { "fk": "param_key_type_id",          "to_table": "param_key_type",          "to_col": "param_key_type_id" },
        { "fk": "param_key_datatype_id",      "to_table": "param_key_datatype",      "to_col": "param_key_datatype_id" },
        { "fk": "param_value_multiplier_id",  "to_table": "param_value_multiplier",  "to_col": "param_value_multiplier_id" }
      ]
    },
    "param_group": {
      "joins": [
        { "fk": "param_category_id", "to_table": "param_category", "to_col": "param_category_id" }
      ]
    },
    "param_category": {
      "joins": [
        { "fk": "param_category_master_id", "to_table": "param_category_master", "to_col": "param_category_master_id" }
      ]
    },
    "association": {
      "joins": [
        { "fk": "association_type_id", "to_table": "association_type", "to_col": "association_type_id" }
      ],
      "note": "association_ref_code = 'US'/'CA' for country scope. association_type_name = 'COUNTRY'/'STORE'/'STATE'."
    },
    "rms_item_config": {
      "joins": [
        { "fk": "param_key_id",           "to_table": "param_key",    "to_col": "param_key_id" },
        { "fk": "association_id",          "to_table": "association",  "to_col": "association_id" },
        { "fk": "parent_association_id",   "to_table": "association",  "to_col": "association_id" },
        { "fk": "store_type_id",           "to_table": "store_type",   "to_col": "store_type_id" }
      ]
    },
    "app_component_function": {
      "joins": [
        { "fk": "app_sub_component_id", "to_table": "app_sub_component", "to_col": "app_sub_component_id" }
      ]
    },
    "app_sub_component": {
      "joins": [
        { "fk": "app_component_id", "to_table": "app_component", "to_col": "app_component_id" }
      ]
    },
    "app_component": {
      "joins": [
        { "fk": "app_id", "to_table": "app", "to_col": "app_id" }
      ]
    },
    "app_role_menu": {
      "joins": [
        { "fk": "app_component_function_id", "to_table": "app_component_function", "to_col": "app_component_function_id" },
        { "fk": "app_role_id",               "to_table": "app_role",               "to_col": "app_role_id" },
        { "fk": "app_user_id",               "to_table": "app_user",               "to_col": "app_user_id" }
      ]
    },
    "app_user_role": {
      "joins": [
        { "fk": "app_user_id", "to_table": "app_user", "to_col": "app_user_id" },
        { "fk": "app_role_id", "to_table": "app_role", "to_col": "app_role_id" }
      ]
    },
    "app_user_location": {
      "joins": [
        { "fk": "app_user_id",                    "to_table": "app_user",                    "to_col": "app_user_id" },
        { "fk": "org_hierarchy_id",               "to_table": "org_hierarchy",               "to_col": "org_hierarchy_id" },
        { "fk": "app_user_locat_assign_type_id",  "to_table": "app_user_locat_assign_type",  "to_col": "app_user_locat_assign_type_id" }
      ]
    },
    "org_attribute": {
      "joins": [
        { "fk": "org_hierarchy_id",   "to_table": "org_hierarchy",   "to_col": "org_hierarchy_id" },
        { "fk": "country_id",         "to_table": "country",         "to_col": "country_id" },
        { "fk": "state_province_id",  "to_table": "state_province",  "to_col": "state_province_id" }
      ]
    },
    "state_province": {
      "joins": [
        { "fk": "country_id",       "to_table": "country",       "to_col": "country_id" },
        { "fk": "tax_template_id",  "to_table": "tax_template",  "to_col": "tax_template_id" }
      ]
    },
    "store": {
      "joins": [
        { "fk": "state_province_id",  "to_table": "state_province",  "to_col": "state_province_id" },
        { "fk": "language_id",        "to_table": "language",        "to_col": "language_id" },
        { "fk": "timezone_id",        "to_table": "timezone",        "to_col": "timezone_id" },
        { "fk": "store_type_id",      "to_table": "store_type",      "to_col": "store_type_id" },
        { "fk": "store_sub_type_id",  "to_table": "store_sub_type",  "to_col": "store_sub_type_id" }
      ]
    },
    "message_config": {
      "joins": [
        { "fk": "association_id",       "to_table": "association",        "to_col": "association_id" },
        { "fk": "company_id",           "to_table": "company",            "to_col": "company_id" },
        { "fk": "message_template_id",  "to_table": "message_template",   "to_col": "message_template_id" }
      ]
    }
  },
  "racadm": {
    "agreement": {
      "joins": [
        { "fk": "store_id",                    "to_table": "store",                    "to_col": "store_id" },
        { "fk": "agreement_type_id",           "to_table": "agreement_type",           "to_col": "agreement_type_id" },
        { "fk": "agreement_status_type_id",    "to_table": "agreement_status_type",    "to_col": "agreement_status_type_id" },
        { "fk": "agreement_status_reason_id",  "to_table": "agreement_status_reason",  "to_col": "agreement_status_reason_id" },
        { "fk": "payment_schedule_id",         "to_table": "payment_schedule",         "to_col": "payment_schedule_id" },
        { "fk": "state_province_id",           "to_table": "state_province",           "to_col": "state_province_id" },
        { "fk": "customer_payment_method_id",  "to_table": "customer_payment_method",  "to_col": "customer_payment_method_id" },
        { "fk": "delivery_address_id",         "to_table": "address",                  "to_col": "address_id" },
        { "fk": "agreement_source_id",         "to_table": "agreement_source",         "to_col": "agreement_source_id" }
      ],
      "note": "Core entity. PK=agreement_id. agreement_number is the business key (character varying)."
    },
    "agreement_customer": {
      "joins": [
        { "fk": "agreement_id", "to_table": "agreement", "to_col": "agreement_id" },
        { "fk": "customer_id",  "to_table": "customer",  "to_col": "customer_id" }
      ],
      "note": "Many-to-many bridge between agreement and customer."
    },
    "agreement_inventory": {
      "joins": [
        { "fk": "agreement_id",       "to_table": "agreement",        "to_col": "agreement_id" },
        { "fk": "inventory_id",       "to_table": "inventory",        "to_col": "inventory_id" },
        { "fk": "inventory_price_id", "to_table": "inventory_price",  "to_col": "inventory_price_id" }
      ]
    },
    "agreement_payment_history": {
      "joins": [
        { "fk": "agreement_id", "to_table": "agreement", "to_col": "agreement_id" },
        { "fk": "receipt_id",   "to_table": "receipt",   "to_col": "receipt_id" },
        { "fk": "store_id",     "to_table": "store",     "to_col": "store_id" }
      ],
      "note": "All payment transactions for an agreement."
    },
    "agreement_status": {
      "joins": [
        { "fk": "agreement_id",             "to_table": "agreement",              "to_col": "agreement_id" },
        { "fk": "agreement_status_type_id", "to_table": "agreement_status_type",  "to_col": "agreement_status_type_id" },
        { "fk": "agreement_status_reason_id","to_table": "agreement_status_reason","to_col": "agreement_status_reason_id" }
      ]
    },
    "agreement_status_type": {
      "joins": [
        { "fk": "agreement_status_group_id", "to_table": "agreement_status_group", "to_col": "agreement_status_group_id" }
      ],
      "note": "ref_code values: ACTIVE, CLOSED, EARLY_PURCHASE, CHARGED_OFF, etc."
    },
    "agreement_status_reason": {
      "joins": [
        { "fk": "agreement_status_type_id", "to_table": "agreement_status_type", "to_col": "agreement_status_type_id" }
      ]
    },
    "agreement_activity_log": {
      "joins": [
        { "fk": "agreement_id",              "to_table": "agreement",              "to_col": "agreement_id" },
        { "fk": "agreement_activity_type_id","to_table": "agreement_activity_type","to_col": "agreement_activity_type_id" }
      ]
    },
    "agreement_param": {
      "joins": [
        { "fk": "agreement_id",  "to_table": "agreement",  "to_col": "agreement_id" },
        { "fk": "param_key_id",  "to_table": "param_key",  "to_col": "param_key_id", "cross_schema": true, "target_schema": "configadm" }
      ],
      "note": "Agreement-level rule overrides. param_key lives in configadm."
    },
    "agreement_promotion": {
      "joins": [
        { "fk": "agreement_id",               "to_table": "agreement",               "to_col": "agreement_id" },
        { "fk": "promotion_id",               "to_table": "promotion",               "to_col": "promotion_id" },
        { "fk": "agreement_promotion_status_id","to_table": "agreement_promotion_status","to_col": "agreement_promotion_status_id" }
      ]
    },
    "agreement_fee": {
      "joins": [
        { "fk": "agreement_id",      "to_table": "agreement",      "to_col": "agreement_id" },
        { "fk": "agreement_fee_type_id","to_table": "agreement_fee_type","to_col": "agreement_fee_type_id" }
      ]
    },
    "agreement_coverage": {
      "joins": [
        { "fk": "agreement_id",   "to_table": "agreement",    "to_col": "agreement_id" },
        { "fk": "coverage_type_id","to_table": "coverage_type","to_col": "coverage_type_id" }
      ]
    },
    "account_management_activity": {
      "joins": [
        { "fk": "store_id",                    "to_table": "store",                   "to_col": "store_id" },
        { "fk": "customer_id",                 "to_table": "customer",                "to_col": "customer_id" },
        { "fk": "account_activity_type_id",    "to_table": "account_activity_type",   "to_col": "account_activity_type_id" },
        { "fk": "account_activity_subtype_id", "to_table": "account_activity_subtype","to_col": "account_activity_subtype_id" },
        { "fk": "agreement_id",                "to_table": "agreement",               "to_col": "agreement_id" },
        { "fk": "call_result_id",              "to_table": "call_result",             "to_col": "call_result_id" }
      ]
    },
    "customer": {
      "joins": [],
      "note": "PK=customer_id. Key fields: email_address, okta_id, first_name, last_name."
    },
    "address": {
      "joins": [
        { "fk": "customer_id",       "to_table": "customer",       "to_col": "customer_id" },
        { "fk": "address_type_id",   "to_table": "address_type",   "to_col": "address_type_id" },
        { "fk": "state_province_id", "to_table": "state_province", "to_col": "state_province_id" },
        { "fk": "country_id",        "to_table": "country",        "to_col": "country_id" }
      ]
    },
    "inventory": {
      "joins": [
        { "fk": "store_id",             "to_table": "store",             "to_col": "store_id" },
        { "fk": "rms_item_master_id",   "to_table": "rms_item_master",   "to_col": "rms_item_master_id" }
      ]
    },
    "inventory_price": {
      "joins": [
        { "fk": "inventory_id", "to_table": "inventory", "to_col": "inventory_id" }
      ],
      "note": "Contains sac_days (integer) and sac_days_printed (integer)."
    },
    "receipt": {
      "joins": [
        { "fk": "store_id",     "to_table": "store",     "to_col": "store_id" },
        { "fk": "customer_id",  "to_table": "customer",  "to_col": "customer_id" }
      ]
    },
    "store": {
      "joins": [],
      "note": "PK=store_id. Business key=store_number (character varying). Cross-schema: configadm.store also exists.",
      "cross_schema_mirror": "configadm.store"
    },
    "override_activity": {
      "joins": [
        { "fk": "store_id", "to_table": "store", "to_col": "store_id" }
      ],
      "note": "Contains sac_days (integer) and sac_days_printed (integer)."
    }
  },
  "cross_schema": {
    "note": "Fields shared between racadm and configadm by naming convention.",
    "shared_keys": [
      { "column": "store_id",     "racadm_table": "store",    "configadm_table": "store" },
      { "column": "param_key_id", "racadm_table": "agreement_param", "configadm_table": "param_key" },
      { "column": "app_user_id",  "racadm_table": "app_user", "configadm_table": "app_user" },
      { "column": "app_role_id",  "racadm_table": "app_role", "configadm_table": "app_role" },
      { "column": "rms_item_master_id", "prcadm_tables": ["product_price","item_price","item_price_hierarchy","cost_pricing_rule","manufacturer_model_master"], "racadm_table": "inventory", "note": "Links pricing data in prcadm to inventory items in racadm." },
      { "column": "store_id", "prcadm_table": "company_store", "racadm_table": "store", "note": "prcadm.company_store.store_id references racadm store." }
    ]
  },
  "prcadm": {
    "category_subtype": {
      "joins": [
        { "fk": "category_type_id", "to_table": "category_type", "to_col": "category_type_id" }
      ]
    },
    "company_store": {
      "joins": [
        { "fk": "company_id", "to_table": "company", "to_col": "company_id" }
      ],
      "note": "company_store.store_id cross-references racadm.store."
    },
    "cost_pricing_rule": {
      "joins": [
        { "fk": "zone_id",            "to_table": "item_price_hierarchy", "to_col": "zone_id",            "note": "zone_id shared with item_price_hierarchy" },
        { "fk": "pricing_queue_id",   "to_table": "pricing_queue",        "to_col": "pricing_queue_id" },
        { "fk": "pricing_upload_id",  "to_table": "pricing_upload",       "to_col": "pricing_upload_id" }
      ],
      "note": "Defines cost-based min/max rate constraints. Scoped by zone + RMS hierarchy."
    },
    "equation_type_param": {
      "joins": [
        { "fk": "equation_type_id", "to_table": "equation_type", "to_col": "equation_type_id" }
      ]
    },
    "item_price": {
      "joins": [
        { "fk": "price_hierarchy_id",  "to_table": "price_hierarchy",      "to_col": "price_hierarchy_id" },
        { "fk": "pricing_queue_id",    "to_table": "pricing_queue",         "to_col": "pricing_queue_id" },
        { "fk": "pricing_upload_id",   "to_table": "pricing_upload",        "to_col": "pricing_upload_id" }
      ],
      "note": "item_price.rms_item_master_id cross-references racadm.inventory.rms_item_master_id."
    },
    "item_price_hierarchy": {
      "joins": [
        { "fk": "zone_id", "to_table": "item_price_hierarchy", "to_col": "item_price_hierarchy_id", "note": "Self-scoped zone reference." }
      ],
      "note": "Defines pricing hierarchy scope by zone and RMS category. rms_item_master_id cross-references racadm."
    },
    "item_subtype": {
      "joins": [
        { "fk": "item_type_id", "to_table": "item_type", "to_col": "item_type_id" }
      ]
    },
    "manufacturer_model_master": {
      "joins": [
        { "fk": "brand_id", "to_table": "brand", "to_col": "brand_id" }
      ],
      "note": "rms_item_master_id cross-references racadm.inventory.rms_item_master_id."
    },
    "package_item": {
      "joins": [
        { "fk": "package_price_id", "to_table": "package_price", "to_col": "package_price_id" }
      ]
    },
    "package_price": {
      "joins": [],
      "note": "zone_id is a business partition key; no FK table named zone in prcadm."
    },
    "pricing_param_key": {
      "joins": [
        { "fk": "pricing_param_group_id", "to_table": "pricing_param_group", "to_col": "pricing_param_group_id" }
      ],
      "note": "pricing_param_key_name is the pricing rule name. Similar role to configadm.param_key."
    },
    "pricing_param_value": {
      "joins": [
        { "fk": "pricing_param_key_id",    "to_table": "pricing_param_key",    "to_col": "pricing_param_key_id" },
        { "fk": "item_price_hierarchy_id", "to_table": "item_price_hierarchy", "to_col": "item_price_hierarchy_id" },
        { "fk": "pricing_queue_id",        "to_table": "pricing_queue",        "to_col": "pricing_queue_id" },
        { "fk": "pricing_upload_id",       "to_table": "pricing_upload",       "to_col": "pricing_upload_id" }
      ],
      "note": "Core value table. Join pricing_param_key for rule name; item_price_hierarchy for scope."
    },
    "pricing_queue": {
      "joins": [
        { "fk": "queue_status_type_id", "to_table": "queue_status_type", "to_col": "queue_status_type_id" },
        { "fk": "queue_type_id",        "to_table": "queue_type",        "to_col": "queue_type_id" }
      ],
      "note": "Pricing approval queue. Filter by queue_status_type.ref_code for status (e.g. PENDING, APPROVED)."
    },
    "pricing_queue_stage": {
      "joins": [
        { "fk": "pricing_queue_id",    "to_table": "pricing_queue",    "to_col": "pricing_queue_id" },
        { "fk": "brand_id",            "to_table": "brand",            "to_col": "brand_id" },
        { "fk": "pricing_param_key_id","to_table": "pricing_param_key","to_col": "pricing_param_key_id" },
        { "fk": "category_type_id",    "to_table": "category_type",    "to_col": "category_type_id" },
        { "fk": "category_subtype_id", "to_table": "category_subtype", "to_col": "category_subtype_id" },
        { "fk": "equation_type_id",    "to_table": "equation_type",    "to_col": "equation_type_id" }
      ],
      "note": "Staged pricing records for a queue. Contains sac_days and sac_days_printed. store_id cross-references racadm.store."
    },
    "pricing_report_association": {
      "joins": [
        { "fk": "pricing_report_id", "to_table": "pricing_report", "to_col": "pricing_report_id" }
      ]
    },
    "pricing_source_detail": {
      "joins": [
        { "fk": "product_price_id",       "to_table": "product_price",       "to_col": "product_price_id" },
        { "fk": "pricing_param_key_id",   "to_table": "pricing_param_key",   "to_col": "pricing_param_key_id" },
        { "fk": "pricing_param_value_id", "to_table": "pricing_param_value", "to_col": "pricing_param_value_id" }
      ]
    },
    "pricing_upload_association": {
      "joins": [
        { "fk": "pricing_upload_id", "to_table": "pricing_upload", "to_col": "pricing_upload_id" }
      ]
    },
    "product_clearance": {
      "joins": [
        { "fk": "pricing_param_value_id", "to_table": "pricing_param_value", "to_col": "pricing_param_value_id" }
      ],
      "note": "rms_item_master_id and rms_item_number cross-reference racadm.inventory."
    },
    "product_price": {
      "joins": [],
      "note": "Published price per item/zone. rms_item_master_id and rms_item_number cross-reference racadm.inventory. Contains sac_days and sac_days_printed."
    }
  }
}